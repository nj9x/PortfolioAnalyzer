APP_NAME=PortfolioAnalyzer
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/to/database.sqlite

SESSION_DRIVER=file
CACHE_STORE=file
QUEUE_CONNECTION=sync

# --- Portfolio Analyzer API Keys ---
ANTHROPIC_API_KEY=your-anthropic-api-key-here
MASSIVE_API_KEY=your-massive-api-key-here
NEWS_API_KEY=your-newsapi-key-here
FRED_API_KEY=your-fred-api-key-here
ALPHA_VANTAGE_API_KEY=

# --- Claude Settings ---
CLAUDE_MODEL=claude-sonnet-4-5-20250929
CLAUDE_MAX_TOKENS=16384

# --- CORS ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Cache TTLs (seconds) ---
STOCK_CACHE_TTL=60
TECHNICAL_CACHE_TTL=120
OPTIONS_CACHE_TTL=120
RISK_CACHE_TTL=120
FUNDAMENTALS_CACHE_TTL=1800
ALPHA_VANTAGE_CACHE_TTL=3600
NEWS_CACHE_TTL=900
POLYMARKET_CACHE_TTL=600
FRED_CACHE_TTL=86400
